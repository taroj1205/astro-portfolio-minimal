---
import '../styles/global.css'
import BgCircles from './bg-circles.astro'

const { title = 'Portfolio', description = "taroj1205's portfolio" } =
  Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" type="image/ico" />
    <link
      rel="preload"
      href="/fonts/InterVariable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <title>taroj1205 - {title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <BgCircles />
    <slot />
    <footer>
      <p>
        &copy; {new Date().getFullYear()}
        <a href="https://x.com/taroj1205" style="text-decoration: none;"
          >taroj1205</a
        >
      </p>
    </footer>
  </body>
</html>
